{
  "name": "naview",
  "version": "0.1.0",
  "description": "Chrome extension for viewing, saving, and exporting Naviance scattergram data",
  "engines": {
    "node": ">=19"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "build": "esbuild content/content.js --bundle --outfile=dist/content.js --format=iife --platform=browser",
    "build:watch": "esbuild content/content.js --bundle --outfile=dist/content.js --format=iife --platform=browser --watch",
    "package": "npm run build && bash scripts/package-extension.sh"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": "babel-jest"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-jest": "^29.7.0",
    "esbuild": "^0.27.4",
    "fake-indexeddb": "^4.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0"
  }
}
